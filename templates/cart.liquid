{% comment %}Cart Page — Repuestos ANSA{% endcomment %}

<div class="cart-page">
  <div class="container">

    <div class="page-header" style="padding: 32px 0 40px;">
      <div class="eyebrow" style="margin-bottom:12px">Tu compra</div>
      <h1 class="heading" style="font-size:clamp(28px,4vw,48px)">Carro de compras</h1>
    </div>

    {% if cart.item_count > 0 %}

      <div class="cart-layout">

        <!-- ITEMS -->
        <div class="cart-items">
          <form action="/cart" method="post" id="cart-form">

            <div class="cart-items__header">
              <span>Producto</span>
              <span>Precio</span>
              <span>Cantidad</span>
              <span>Total</span>
            </div>

            {% for item in cart.items %}
              <div class="cart-item-row" data-item-key="{{ item.key }}">

                <!-- Image + info -->
                <div class="cart-item-row__product">
                  <a href="{{ item.url }}" class="cart-item-row__img">
                    <img
                      src="{{ item.product.featured_image | img_url: '160x160', crop: 'center' }}"
                      alt="{{ item.product.title }}"
                      width="80" height="80"
                      loading="lazy"
                    >
                  </a>
                  <div class="cart-item-row__meta">
                    <div class="cart-item-row__vendor">{{ item.vendor }}</div>
                    <a href="{{ item.url }}" class="cart-item-row__title">{{ item.product.title }}</a>
                    {% if item.variant.title != 'Default Title' %}
                      <div class="cart-item-row__variant">{{ item.variant.title }}</div>
                    {% endif %}
                    <button
                      type="button"
                      class="cart-item-row__remove"
                      onclick="ANSA.cartRemove('{{ item.key }}')"
                      aria-label="Eliminar {{ item.product.title }}"
                    >
                      Eliminar
                    </button>
                  </div>
                </div>

                <!-- Unit price -->
                <div class="cart-item-row__price">
                  {{ item.price | money }}
                </div>

                <!-- Quantity -->
                <div class="cart-item-row__qty">
                  <div class="qty-control" style="width:fit-content">
                    <button type="button" onclick="ANSA.cartQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      max="99"
                      class="qty-input"
                      data-key="{{ item.key }}"
                      onchange="ANSA.cartQty('{{ item.key }}', this.value)"
                    >
                    <button type="button" onclick="ANSA.cartQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
                  </div>
                </div>

                <!-- Line total -->
                <div class="cart-item-row__total">
                  {{ item.final_line_price | money }}
                </div>

              </div>
            {% endfor %}

          </form>
        </div>

        <!-- SUMMARY -->
        <div class="cart-summary">
          <div class="cart-summary__inner">
            <h2>Resumen de orden</h2>

            <div class="cart-summary__line">
              <span>Subtotal ({{ cart.item_count }} productos)</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <div class="cart-summary__line cart-summary__shipping">
              <span>Despacho</span>
              <span>
                {% if cart.total_price >= 5000000 %}
                  <span style="color:var(--color-success)">Gratis</span>
                {% else %}
                  Calculado al pagar
                {% endif %}
              </span>
            </div>

            <div class="cart-summary__divider"></div>

            <div class="cart-summary__total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <a href="/checkout" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:24px;padding:18px;">
              Ir al pago →
            </a>

            <a href="/" class="btn btn-secondary" style="width:100%;justify-content:center;margin-top:10px;">
              Seguir comprando
            </a>

            <div class="cart-summary__trust">
              <span>🔒 Pago seguro</span>
              <span>🚚 Despacho a todo Chile</span>
            </div>
          </div>
        </div>

      </div>

    {% else %}
      <div class="cart-empty-page">
        <div class="cart-empty-page__icon">🛒</div>
        <h2>Tu carro está vacío</h2>
        <p>Selecciona la marca y modelo de tu vehículo para encontrar los repuestos que necesitas.</p>
        <a href="/" class="btn btn-primary" style="margin-top:24px">Buscar repuestos</a>
      </div>
    {% endif %}

  </div>
</div>

<style>
.cart-page { padding-bottom: 80px; }
.cart-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 40px;
  align-items: start;
}

/* Header row */
.cart-items__header {
  display: grid;
  grid-template-columns: 3fr 1fr 1fr 1fr;
  gap: 16px;
  padding: 0 0 14px;
  border-bottom: 1px solid var(--color-border);
  font-family: var(--font-heading);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--color-muted);
}

/* Item row */
.cart-item-row {
  display: grid;
  grid-template-columns: 3fr 1fr 1fr 1fr;
  gap: 16px;
  align-items: center;
  padding: 20px 0;
  border-bottom: 1px solid var(--color-border);
}
.cart-item-row__product {
  display: flex;
  gap: 16px;
  align-items: center;
}
.cart-item-row__img {
  width: 80px; height: 80px;
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  padding: 6px;
}
.cart-item-row__img img { width: 100%; height: 100%; object-fit: contain; }
.cart-item-row__vendor {
  font-family: var(--font-heading);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 4px;
}
.cart-item-row__title {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 15px;
  text-transform: uppercase;
  line-height: 1.2;
  color: var(--color-text);
  transition: color var(--transition);
}
.cart-item-row__title:hover { color: var(--color-accent); }
.cart-item-row__variant { font-size: 12px; color: var(--color-muted); margin-top: 4px; }
.cart-item-row__remove {
  background: none;
  border: none;
  color: var(--color-muted);
  font-size: 11px;
  cursor: pointer;
  padding: 0;
  margin-top: 8px;
  text-decoration: underline;
  transition: color var(--transition);
  display: block;
}
.cart-item-row__remove:hover { color: var(--color-accent); }
.cart-item-row__price,
.cart-item-row__total {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 16px;
}

/* Summary */
.cart-summary__inner {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 28px;
  position: sticky;
  top: 90px;
}
.cart-summary__inner h2 {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 18px;
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--color-border);
}
.cart-summary__line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
  color: var(--color-muted);
  margin-bottom: 12px;
}
.cart-summary__divider { height: 1px; background: var(--color-border); margin: 16px 0; }
.cart-summary__total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 20px;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.cart-summary__trust {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid var(--color-border);
  font-size: 12px;
  color: var(--color-muted);
}

/* Empty */
.cart-empty-page {
  text-align: center;
  padding: 80px 20px;
}
.cart-empty-page__icon { font-size: 64px; margin-bottom: 24px; }
.cart-empty-page h2 {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 32px;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.cart-empty-page p { color: var(--color-muted); max-width: 380px; margin: 0 auto; }

@media (max-width: 900px) {
  .cart-layout { grid-template-columns: 1fr; }
  .cart-items__header { display: none; }
  .cart-item-row { grid-template-columns: 1fr; gap: 12px; }
}
</style>

<script>
window.ANSA = window.ANSA || {};

ANSA.cartQty = async function(key, qty) {
  await fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: key, quantity: Math.max(0, parseInt(qty)) })
  });
  window.location.reload();
};

ANSA.cartRemove = function(key) {
  ANSA.cartQty(key, 0);
};
</script>
