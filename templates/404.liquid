{% comment %}404 Template — Repuestos ANSA{% endcomment %}

<div class="error-page">
  <div class="container">
    <div class="error-page__content">
      <div class="error-page__code">404</div>
      <h1 class="heading" style="font-size:clamp(28px,4vw,48px); margin-bottom: 16px;">
        Página no encontrada
      </h1>
      <p>La página que buscas no existe o fue movida.</p>
      <div style="display:flex; gap:14px; flex-wrap:wrap; margin-top:32px; justify-content:center;">
        <a href="/" class="btn btn-primary">Ir al inicio</a>
        <a href="/search" class="btn btn-secondary">Buscar repuesto</a>
      </div>
    </div>
  </div>
</div>

<style>
.error-page {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.error-page__content { text-align: center; }
.error-page__code {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(80px, 15vw, 160px);
  line-height: 1;
  color: var(--color-border);
  margin-bottom: 16px;
  letter-spacing: -.02em;
}
.error-page__content p {
  color: var(--color-muted);
  font-size: 16px;
  margin-top: 8px;
}
</style>
