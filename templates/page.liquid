{% comment %}Generic Page Template — Repuestos ANSA{% endcomment %}

<div class="page-generic">
  <div class="container">

    <div class="page-header" style="padding: 40px 0 48px; border-bottom: 1px solid var(--color-border); margin-bottom: 48px;">
      <div class="eyebrow" style="margin-bottom: 14px;">Repuestos ANSA</div>
      <h1 class="heading" style="font-size: clamp(32px, 4vw, 56px);">{{ page.title }}</h1>
    </div>

    <div class="page-content rte">
      {{ page.content }}
    </div>

  </div>
</div>

<style>
.page-generic { padding-bottom: 80px; }
.rte { max-width: 760px; }
.rte h2, .rte h3 {
  font-family: var(--font-heading);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin: 32px 0 16px;
}
.rte h2 { font-size: 28px; }
.rte h3 { font-size: 22px; }
.rte p { color: var(--color-muted); font-size: 15px; line-height: 1.7; margin-bottom: 16px; }
.rte ul, .rte ol { color: var(--color-muted); font-size: 15px; line-height: 1.7; padding-left: 20px; margin-bottom: 16px; }
.rte li { margin-bottom: 8px; }
.rte a { color: var(--color-accent); text-decoration: underline; }
.rte strong { color: var(--color-text); font-weight: 500; }
</style>
