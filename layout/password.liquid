<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#0a0a0c;color:#f0eff5;font-family:sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
    .wrap{text-align:center;max-width:420px;padding:40px 24px}
    .logo{font-family:Impact,sans-serif;font-weight:800;font-size:28px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:32px}
    .logo span{color:#e8350f}
    p{color:#7a7a8a;font-size:14px;line-height:1.6;margin-bottom:20px}
    input[type=password]{background:#18181d;border:1px solid #2a2a33;color:#f0eff5;padding:12px 16px;width:100%;font-size:14px;margin-bottom:12px;outline:none}
    input[type=password]:focus{border-color:#e8350f}
    button{background:#e8350f;color:white;border:none;padding:14px 32px;width:100%;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;cursor:pointer}
    button:hover{background:#ff6b3d}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">Repuestos <span>ANSA</span></div>
    {{ content_for_layout }}
  </div>
</body>
</html>
