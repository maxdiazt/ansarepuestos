<!doctype html>
<html lang="es" class="no-js">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a0c">

  <title>
    {{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}
    {% if current_page != 1 %} – Página {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'ansa.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}">

  <!-- ══ TOPBAR ══════════════════════════════════════════════ -->
  <div class="topbar">
    <div class="container topbar__inner">
      <span class="topbar__left">
        <span class="topbar__dot"></span>
        Despacho a todo Chile &middot; Envío gratis sobre ${{ settings.free_shipping_threshold | default: '50.000' }}
      </span>
      <span class="topbar__right hide-mobile">
        {{ settings.store_hours }} &middot; {{ settings.store_phone }}
      </span>
    </div>
  </div>

  <!-- ══ HEADER ═══════════════════════════════════════════════ -->
  <header class="site-header" role="banner">
    <div class="container site-header__inner">

      <!-- Logo -->
      <a href="/" class="site-header__logo" aria-label="{{ shop.name }}">
        <div class="logo-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12,2 22,7 22,17 12,22 2,17 2,7"/>
            <polyline points="12,22 12,12"/>
            <polyline points="22,7 12,12 2,7"/>
          </svg>
        </div>
        <div class="logo-text">
          Repuestos <span>ANSA</span>
        </div>
      </a>

      <!-- Nav Desktop -->
      <nav class="site-header__nav hide-mobile" role="navigation" aria-label="Menú principal">
        <a href="/">Inicio</a>
        <a href="/pages/marcas">Marcas</a>
        <a href="/collections/ofertas">Ofertas</a>
        <a href="/pages/consulta-tecnica">Consulta técnica</a>
        <a href="/pages/contacto">Contacto</a>
      </nav>

      <!-- Actions -->
      <div class="site-header__actions">
        <a href="/search" class="btn-icon hide-mobile" aria-label="Buscar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </a>

        {% if shop.customer_accounts_enabled %}
          <a href="/account" class="btn-icon hide-mobile" aria-label="Mi cuenta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        {% endif %}

        <button class="btn-icon cart-badge" data-cart-toggle aria-label="Carro de compras">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="badge" data-cart-count style="display:none">0</span>
        </button>

        <!-- Mobile toggle -->
        <button class="btn-icon hide-desktop" id="nav-toggle" aria-expanded="false" aria-label="Menú">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>

    </div>
  </header>

  <!-- ══ MOBILE NAV ════════════════════════════════════════════ -->
  <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <div class="mobile-nav__inner">
      <a href="/">Inicio</a>
      <a href="/pages/marcas">Marcas</a>
      <a href="/collections/ofertas">Ofertas</a>
      <a href="/pages/consulta-tecnica">Consulta técnica</a>
      <a href="/pages/contacto">Contacto</a>
      <a href="/search">Buscar</a>
      {% if shop.customer_accounts_enabled %}
        <a href="/account">Mi cuenta</a>
      {% endif %}
    </div>
  </nav>

  <!-- ══ MAIN ══════════════════════════════════════════════════ -->
  <main role="main" id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- ══ FOOTER ════════════════════════════════════════════════ -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="site-footer__grid">

        <div class="site-footer__brand">
          <div class="logo-text" style="font-size:20px">Repuestos <span style="color:var(--color-accent)">ANSA</span></div>
          <p>Repuestos originales y alternativos para Renault, Mazda, Suzuki, Great Wall y Changan en Chile.</p>
          <div class="site-footer__contact">
            <span>{{ settings.store_phone }}</span>
            <span>{{ settings.store_hours }}</span>
          </div>
        </div>

        <div class="site-footer__col">
          <h4>Marcas</h4>
          <ul>
            <li><a href="/collections/renault">Renault</a></li>
            <li><a href="/collections/mazda">Mazda</a></li>
            <li><a href="/collections/suzuki">Suzuki</a></li>
            <li><a href="/collections/great-wall">Great Wall</a></li>
            <li><a href="/collections/changan">Changan</a></li>
          </ul>
        </div>

        <div class="site-footer__col">
          <h4>Categorías</h4>
          <ul>
            <li><a href="/collections/mantencion">Mantención</a></li>
            <li><a href="/collections/desgaste">Desgaste</a></li>
            <li><a href="/collections/reparacion">Reparación</a></li>
            <li><a href="/collections/carroceria">Carrocería</a></li>
            <li><a href="/collections/especialidades">Especialidades</a></li>
            <li><a href="/collections/accesorios-y-herramientas">Accesorios</a></li>
          </ul>
        </div>

        <div class="site-footer__col">
          <h4>Información</h4>
          <ul>
            <li><a href="/pages/nosotros">Nosotros</a></li>
            <li><a href="/pages/consulta-tecnica">Consulta técnica</a></li>
            <li><a href="/pages/contacto">Contacto</a></li>
            <li><a href="/policies/shipping-policy">Despacho</a></li>
            <li><a href="/policies/refund-policy">Devoluciones</a></li>
            <li><a href="/policies/privacy-policy">Privacidad</a></li>
          </ul>
        </div>

      </div>

      <div class="site-footer__bottom">
        <span>&copy; {{ 'now' | date: '%Y' }} <strong>Repuestos ANSA</strong> &middot; Todos los derechos reservados</span>
        <div class="site-footer__brands">Renault &middot; Mazda &middot; Suzuki &middot; Great Wall &middot; Changan</div>
      </div>
    </div>
  </footer>

  <!-- ══ CART DRAWER ═══════════════════════════════════════════ -->
  <div class="cart-overlay" id="cart-overlay"></div>
  <div class="cart-drawer" id="cart-drawer" aria-label="Carro de compras">
    <div class="cart-drawer__header">
      <h2>Tu carro</h2>
      <button class="btn-icon" data-cart-toggle aria-label="Cerrar carro">✕</button>
    </div>
    <div class="cart-drawer__items" id="cart-drawer-items">
      <p>Cargando...</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__total">
        <span>Total</span>
        <span id="cart-drawer-total">$0</span>
      </div>
      <a href="/checkout" class="btn btn-primary" style="width:100%;justify-content:center;">Ir al pago</a>
      <a href="/cart" class="btn btn-secondary" style="width:100%;justify-content:center;margin-top:8px;">Ver carro completo</a>
    </div>
  </div>

  <!-- ══ CART NOTIFICATION ═════════════════════════════════════ -->
  <div class="cart-notification" id="cart-notification" role="status" aria-live="polite">
    <span>✓</span>
    <span data-notification-title>Producto</span>
    <span>agregado al carro</span>
  </div>

  <!-- ══ SCRIPTS ═══════════════════════════════════════════════ -->
  {{ 'ansa.js' | asset_url | script_tag }}
</body>
</html>
