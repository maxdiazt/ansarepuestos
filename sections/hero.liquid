<section class="hero-section">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="eyebrow animate-fade-up">Especialistas en repuestos originales y alternativos</div>
      <h1 class="heading hero-heading animate-fade-up delay-1">
        {{ section.settings.heading_line1 | default: 'Repuestos para' }}<br>
        <em>{{ section.settings.heading_line2 | default: 'tu auto,' }}</em><br>
        {{ section.settings.heading_line3 | default: 'al precio justo.' }}
      </h1>
      <p class="hero-sub animate-fade-up delay-2">
        {{ section.settings.subheading | default: 'Selecciona tu marca, modelo y categoría. Encontrarás el repuesto exacto que necesitas.' }}
      </p>
      <div class="hero-cta animate-fade-up delay-3">
        <a href="#brand-selector" class="btn btn-primary">Buscar repuesto</a>
        <a href="/pages/consulta-tecnica" class="btn btn-secondary">Consulta técnica</a>
      </div>
    </div>

    <div class="hero-stats hide-mobile animate-fade-up delay-2" aria-label="Estadísticas">
      <div class="hero-stat">
        <div class="hero-stat__number">5</div>
        <div class="hero-stat__label">Marcas</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat__number">+2K</div>
        <div class="hero-stat__label">Productos</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat__number">48h</div>
        <div class="hero-stat__label">Despacho</div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-section {
  position: relative;
  padding: 80px 0 90px;
  border-bottom: 1px solid var(--color-border);
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 70% 50%, rgba(232,53,15,.07) 0%, transparent 70%),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 39px,
      rgba(255,255,255,.016) 39px,
      rgba(255,255,255,.016) 40px
    );
}
.hero-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  position: relative;
}
.hero-content { flex: 1; max-width: 680px; }
.hero-heading {
  font-size: clamp(44px, 5.5vw, 76px);
  margin: 20px 0 24px;
}
.hero-heading em {
  font-style: normal;
  color: var(--color-accent);
}
.hero-sub {
  color: var(--color-muted);
  font-size: 16px;
  max-width: 460px;
  line-height: 1.65;
  margin-bottom: 36px;
}
.hero-cta { display: flex; gap: 14px; flex-wrap: wrap; }
.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 20px;
  flex-shrink: 0;
}
.hero-stat {
  text-align: right;
  border-right: 2px solid var(--color-accent);
  padding-right: 18px;
}
.hero-stat__number {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 38px;
  line-height: 1;
}
.hero-stat__label {
  font-size: 11px;
  color: var(--color-muted);
  letter-spacing: .08em;
  text-transform: uppercase;
}
@media (max-width: 768px) {
  .hero-section { padding: 60px 0; }
  .hero-heading { font-size: 40px; }
}
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "heading_line1", "label": "Título línea 1", "default": "Repuestos para" },
    { "type": "text", "id": "heading_line2", "label": "Título línea 2 (acento)", "default": "tu auto," },
    { "type": "text", "id": "heading_line3", "label": "Título línea 3", "default": "al precio justo." },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Selecciona tu marca, modelo y categoría. Encontrarás el repuesto exacto que necesitas para Renault, Mazda, Suzuki, Great Wall y Changan." }
  ],
  "presets": [{ "name": "Hero ANSA" }]
}
{% endschema %}
