{% comment %}
  Brand Selector Section
  El flujo principal: Marca → Modelo → Categoría → Colección
{% endcomment %}

{% render 'brand-data' %}

<section class="brand-selector" id="brand-selector">

  <!-- PASO 1: MARCAS -->
  <div class="bs-step bs-step--marcas">
    <div class="container">
      <div class="section-label">
        <h2>01 — Selecciona tu marca</h2>
      </div>

      <div class="bs-marcas-grid" id="bs-marcas-grid">

        {% assign marcas_list = 'renault,mazda,suzuki,great-wall,changan' | split: ',' %}
        {% assign marcas_counts = '18,12,10,7,10' | split: ',' %}
        {% assign marcas_names  = 'Renault,Mazda,Suzuki,Great Wall,Changan' | split: ',' %}
        {% assign marcas_icons  = '◇,⊙,S,⬡,C' | split: ',' %}

        {% for marca in marcas_list %}
          {% assign idx = forloop.index0 %}
          <button
            class="bs-marca-card"
            data-marca="{{ marca }}"
            aria-label="Seleccionar {{ marcas_names[idx] }}"
            onclick="ANSA.selectMarca('{{ marca }}')"
          >
            <div class="bs-marca-icon" aria-hidden="true">
              <div class="bs-marca-ring">{{ marcas_icons[idx] }}</div>
              <span>{{ marcas_names[idx] | upcase }}</span>
            </div>
            <div class="bs-marca-name">{{ marcas_names[idx] }}</div>
            <div class="bs-marca-count">{{ marcas_counts[idx] }} modelos</div>
          </button>
        {% endfor %}

      </div>
    </div>
  </div>

  <!-- PASO 2: MODELOS (se despliega dinámicamente) -->
  <div class="bs-step bs-step--modelos" id="bs-modelos-panel" aria-live="polite" aria-label="Selección de modelo">
    <div class="container">
      <div class="bs-panel-header">
        <div class="bs-panel-title">
          <span class="eyebrow" style="font-size:11px;margin-bottom:0">02 — Modelo</span>
          <h3 id="bs-marca-selected-name">&nbsp;</h3>
        </div>
        <button class="btn-outline" onclick="ANSA.closeModelos()" aria-label="Volver a marcas">
          ← Cambiar marca
        </button>
      </div>
      <div class="bs-modelos-grid" id="bs-modelos-grid" role="list"></div>
    </div>
  </div>

  <!-- PASO 3: CATEGORÍAS (aparece al seleccionar modelo) -->
  <div class="bs-step bs-step--categorias" id="bs-categorias-panel" aria-live="polite">
    <div class="container">
      <div class="section-label">
        <h2 id="bs-categorias-title">03 — Selecciona categoría</h2>
      </div>
      <div class="bs-categorias-grid" id="bs-categorias-grid"></div>
    </div>
  </div>

</section>

<!-- ── STYLES ────────────────────────────────────────────────── -->
<style>
.brand-selector {
  padding-bottom: 16px;
}
.bs-step { padding: 56px 0; border-bottom: 1px solid var(--color-border); }
.bs-step--modelos,
.bs-step--categorias {
  display: none;
  background: var(--color-surface);
  border-top: 2px solid var(--color-accent);
  animation: fadeUp .4s cubic-bezier(.16,1,.3,1) both;
}
.bs-step--modelos.is-open,
.bs-step--categorias.is-open { display: block; }

/* MARCAS */
.bs-marcas-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14px;
}
.bs-marca-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 32px 20px 24px;
  cursor: pointer;
  transition: all var(--transition);
  text-align: center;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.bs-marca-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--color-accent), transparent 60%);
  opacity: 0;
  transition: opacity var(--transition);
}
.bs-marca-card:hover,
.bs-marca-card.is-active {
  border-color: var(--color-accent);
  transform: translateY(-4px);
  box-shadow: var(--shadow-hover);
}
.bs-marca-card.is-active::before,
.bs-marca-card:hover::before { opacity: .07; }

.bs-marca-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  position: relative;
  z-index: 1;
}
.bs-marca-ring {
  width: 56px; height: 56px;
  border: 2px solid var(--color-border);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  color: var(--color-muted);
  transition: all var(--transition);
}
.bs-marca-card:hover .bs-marca-ring,
.bs-marca-card.is-active .bs-marca-ring {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: rgba(232,53,15,.08);
}
.bs-marca-icon > span {
  font-family: var(--font-heading);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .12em;
  color: var(--color-muted);
  transition: color var(--transition);
}
.bs-marca-card:hover .bs-marca-icon > span,
.bs-marca-card.is-active .bs-marca-icon > span { color: var(--color-accent); }

.bs-marca-name {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 18px;
  letter-spacing: .04em;
  text-transform: uppercase;
  position: relative;
  z-index: 1;
}
.bs-marca-count {
  font-size: 11px;
  color: var(--color-muted);
  position: relative;
  z-index: 1;
  transition: color var(--transition);
}
.bs-marca-card.is-active .bs-marca-count { color: var(--color-accent); }

/* PANEL MODELOS */
.bs-panel-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
}
.bs-panel-title h3 {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 32px;
  text-transform: uppercase;
  letter-spacing: -.01em;
  line-height: 1;
  margin-top: 6px;
}
.bs-modelos-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.bs-modelo-chip {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  color: var(--color-text);
  padding: 10px 20px;
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 13px;
  letter-spacing: .06em;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
}
.bs-modelo-chip:hover {
  background: rgba(232,53,15,.08);
  border-color: var(--color-accent);
  color: var(--color-accent);
}
.bs-modelo-chip.is-active {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: white;
}

/* CATEGORÍAS */
.bs-categorias-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}
.bs-cat-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 28px 16px 20px;
  cursor: pointer;
  text-align: center;
  transition: all var(--transition);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.bs-cat-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-3px);
  box-shadow: var(--shadow-hover);
}
.bs-cat-icon { font-size: 28px; line-height: 1; }
.bs-cat-name {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--color-text);
  line-height: 1.2;
  transition: color var(--transition);
}
.bs-cat-card:hover .bs-cat-name { color: var(--color-accent); }
.bs-cat-count { font-size: 11px; color: var(--color-muted); }

/* RESPONSIVE */
@media (max-width: 1100px) {
  .bs-marcas-grid { grid-template-columns: repeat(3, 1fr); }
  .bs-categorias-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .bs-marcas-grid { grid-template-columns: repeat(2, 1fr); }
  .bs-categorias-grid { grid-template-columns: repeat(2, 1fr); }
  .bs-panel-header { flex-direction: column; align-items: flex-start; }
}
</style>

<!-- ── SCRIPT ─────────────────────────────────────────────────── -->
<script>
(function() {
  // Datos desde snippet brand-data
  const DATA = {{ brand_data_json }};

  window.ANSA = window.ANSA || {};

  // Mapas de datos
  const marcaMap = {};
  DATA.marcas.forEach(m => { marcaMap[m.handle] = m; });

  const categoriaData = DATA.categorias;

  let selectedMarca  = null;
  let selectedModelo = null;

  ANSA.selectMarca = function(handle) {
    selectedMarca  = handle;
    selectedModelo = null;

    // Actualizar estado visual de cards
    document.querySelectorAll('.bs-marca-card').forEach(c => {
      c.classList.toggle('is-active', c.dataset.marca === handle);
    });

    // Poblar modelos
    const grid = document.getElementById('bs-modelos-grid');
    const marca = marcaMap[handle];

    grid.innerHTML = marca.modelos.map(m => `
      <button class="bs-modelo-chip" role="listitem" onclick="ANSA.selectModelo('${m.replace(/'/g,"\\'")}')">
        ${m}
      </button>
    `).join('');

    document.getElementById('bs-marca-selected-name').textContent = marca.nombre;

    // Mostrar panel modelos
    const modelPanel = document.getElementById('bs-modelos-panel');
    modelPanel.classList.add('is-open');
    // Ocultar categorías
    document.getElementById('bs-categorias-panel').classList.remove('is-open');

    // Scroll suave
    setTimeout(() => {
      modelPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 60);
  };

  ANSA.selectModelo = function(modelo) {
    selectedModelo = modelo;

    document.querySelectorAll('.bs-modelo-chip').forEach(c => {
      c.classList.toggle('is-active', c.textContent.trim() === modelo);
    });

    // Construir grid de categorías con links reales a colecciones Shopify
    // URL pattern: /collections/{marca}--{modelo-slug}--{categoria-handle}
    const marcaHandle = selectedMarca;
    const modeloSlug  = modelo.toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^a-z0-9-]/g, '')
      .replace(/-+/g, '-');

    const grid = document.getElementById('bs-categorias-grid');
    grid.innerHTML = categoriaData.map(cat => {
      const collectionHandle = `${marcaHandle}--${modeloSlug}--${cat.handle}`;
      return `
        <a
          href="/collections/${collectionHandle}"
          class="bs-cat-card"
          title="${cat.label} para ${ANSA.getMarcaNombre()} ${modelo}"
        >
          <span class="bs-cat-icon" aria-hidden="true">${cat.icono}</span>
          <span class="bs-cat-name">${cat.label}</span>
        </a>
      `;
    }).join('');

    // Actualizar título
    document.getElementById('bs-categorias-title').textContent =
      `03 — Categoría · ${ANSA.getMarcaNombre()} ${modelo}`;

    // Mostrar
    const catPanel = document.getElementById('bs-categorias-panel');
    catPanel.classList.add('is-open');

    setTimeout(() => {
      catPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 60);
  };

  ANSA.getMarcaNombre = function() {
    return selectedMarca ? (marcaMap[selectedMarca]?.nombre || '') : '';
  };

  ANSA.closeModelos = function() {
    selectedMarca  = null;
    selectedModelo = null;
    document.querySelectorAll('.bs-marca-card').forEach(c => c.classList.remove('is-active'));
    document.getElementById('bs-modelos-panel').classList.remove('is-open');
    document.getElementById('bs-categorias-panel').classList.remove('is-open');
    document.getElementById('brand-selector').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

})();
</script>

{% schema %}
{
  "name": "Selector de Marcas",
  "tag": "div",
  "class": "section-brand-selector",
  "presets": [
    {
      "name": "Selector de Marcas ANSA"
    }
  ]
}
{% endschema %}
