{% assign modelos_renault   = "Logan,Sandero,Sandero Stepway,Duster,Kwid,Symbol,Megane,Fluence,Clio,Captur,Koleos,Kangoo,Master,Trafic,Scenic,Laguna,Latitude,Express" | split: "," %}
{% assign modelos_mazda     = "Mazda 2,Mazda 3,Mazda 6,CX-3,CX-5,CX-9,BT-50,MX-5,CX-30,CX-50,323,626" | split: "," %}
{% assign modelos_suzuki    = "Swift,Vitara,Grand Vitara,Jimny,Baleno,Dzire,Ciaz,Ignis,S-Cross,Alto" | split: "," %}
{% assign modelos_greatwall = "Wingle 5,Wingle 7,H1,H2,H5,H6,Voleex C30" | split: "," %}
{% assign modelos_changan   = "CS35,CS35 Plus,CS55,CS55 Plus,CS75,Alsvin,Eado,UNI-T,Oshan X5,CS95" | split: "," %}

{% assign cat_handles = "mantencion,desgaste,reparacion,carroceria,especialidades,accesorios-y-herramientas" | split: "," %}
{% assign cat_labels  = "Mantencion,Desgaste,Reparacion,Carroceria,Especialidades,Accesorios y Herramientas" | split: "," %}
{% assign cat_iconos  = "🔧,⚙️,🔩,🚗,⚡,🛠️" | split: "," %}

<section class="brand-selector" id="brand-selector">

  <div class="bs-step bs-step--marcas">
    <div class="container">
      <div class="bs-section-label"><h2>01 — Selecciona tu marca</h2></div>
      <div class="bs-marcas-grid">

        <button class="bs-marca-card" data-marca="renault" data-nombre="Renault" data-modelos="{{ modelos_renault | join: '|' }}" onclick="ANSA.selectMarca(this)">
          <div class="bs-marca-logo">
            <img src="https://cdn.shopify.com/s/files/1/0822/4296/1620/files/marca-auto-renault.webp?v=1774955401" alt="Renault">
          </div>
          <div class="bs-marca-name">Renault</div>
          <div class="bs-marca-count">{{ modelos_renault | size }} modelos</div>
        </button>

        <button class="bs-marca-card" data-marca="mazda" data-nombre="Mazda" data-modelos="{{ modelos_mazda | join: '|' }}" onclick="ANSA.selectMarca(this)">
          <div class="bs-marca-logo">
            <img src="https://cdn.shopify.com/s/files/1/0822/4296/1620/files/marca-auto-mazda.webp?v=1774955401" alt="Mazda">
          </div>
          <div class="bs-marca-name">Mazda</div>
          <div class="bs-marca-count">{{ modelos_mazda | size }} modelos</div>
        </button>

        <button class="bs-marca-card" data-marca="suzuki" data-nombre="Suzuki" data-modelos="{{ modelos_suzuki | join: '|' }}" onclick="ANSA.selectMarca(this)">
          <div class="bs-marca-logo">
            <img src="https://cdn.shopify.com/s/files/1/0822/4296/1620/files/marca-auto-suzuki.webp?v=1774955401" alt="Suzuki">
          </div>
          <div class="bs-marca-name">Suzuki</div>
          <div class="bs-marca-count">{{ modelos_suzuki | size }} modelos</div>
        </button>

        <button class="bs-marca-card" data-marca="great-wall" data-nombre="Great Wall" data-modelos="{{ modelos_greatwall | join: '|' }}" onclick="ANSA.selectMarca(this)">
          <div class="bs-marca-logo">
            <img src="https://cdn.shopify.com/s/files/1/0822/4296/1620/files/marca-auto-great-wall.webp?v=1774955401" alt="Great Wall">
          </div>
          <div class="bs-marca-name">Great Wall</div>
          <div class="bs-marca-count">{{ modelos_greatwall | size }} modelos</div>
        </button>

        <button class="bs-marca-card" data-marca="changan" data-nombre="Changan" data-modelos="{{ modelos_changan | join: '|' }}" onclick="ANSA.selectMarca(this)">
          <div class="bs-marca-logo">
            <img src="https://cdn.shopify.com/s/files/1/0822/4296/1620/files/marca-auto-changan.webp?v=1774955401" alt="Changan">
          </div>
          <div class="bs-marca-name">Changan</div>
          <div class="bs-marca-count">{{ modelos_changan | size }} modelos</div>
        </button>

      </div>
    </div>
  </div>

  <div class="bs-step bs-step--modelos" id="bs-modelos-panel">
    <div class="container">
      <div class="bs-panel-header">
        <div class="bs-panel-title">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#e8350f">02 — Modelo</div>
          <h3 id="bs-marca-selected-name">&nbsp;</h3>
        </div>
        <button class="bs-btn-outline" onclick="ANSA.closeModelos()">&#8592; Cambiar marca</button>
      </div>
      <div class="bs-modelos-grid" id="bs-modelos-grid"></div>
    </div>
  </div>

  <div class="bs-step bs-step--categorias" id="bs-categorias-panel">
    <div class="container">
      <div class="bs-section-label">
        <h2 id="bs-categorias-title">03 — Selecciona categoria de repuesto</h2>
      </div>
      <div class="bs-categorias-grid">
        {% for handle in cat_handles %}
          {% assign idx = forloop.index0 %}
          <a class="bs-cat-card" href="#" onclick="return ANSA.goToCollection('{{ handle }}')">
            <span class="bs-cat-icon">{{ cat_iconos[idx] }}</span>
            <span class="bs-cat-name">{{ cat_labels[idx] }}</span>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>

</section>

<style>
.brand-selector { padding-bottom: 16px; }
.bs-step { padding: 56px 0; border-bottom: 1px solid #2a2a33; }
.bs-step--modelos, .bs-step--categorias { display: none; background: #111114; border-top: 2px solid #e8350f; }
.bs-step--modelos.is-open, .bs-step--categorias.is-open { display: block; }
.bs-section-label { display: flex; align-items: center; gap: 14px; margin-bottom: 32px; }
.bs-section-label h2 { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: #7a7a8a; white-space: nowrap; }
.bs-section-label::after { content: ''; flex: 1; height: 1px; background: #2a2a33; }
.bs-marcas-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
.bs-marca-card {
  background: #18181d; border: 1px solid #2a2a33; border-radius: 4px;
  padding: 28px 20px 20px; cursor: pointer; transition: all .22s ease;
  text-align: center; display: flex; flex-direction: column; align-items: center; gap: 14px; width: 100%;
}
.bs-marca-card:hover, .bs-marca-card.is-active {
  border-color: #e8350f; transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(232,53,15,.15);
}
.bs-marca-logo {
  width: 100%; height: 60px;
  display: flex; align-items: center; justify-content: center;
}
.bs-marca-logo img {
  max-width: 100%; max-height: 60px;
  object-fit: contain;
  filter: grayscale(1) brightness(1.8);
  transition: filter .22s;
}
.bs-marca-card:hover .bs-marca-logo img,
.bs-marca-card.is-active .bs-marca-logo img {
  filter: grayscale(0) brightness(1);
}
.bs-marca-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 16px; letter-spacing: .04em; text-transform: uppercase; color: #f0eff5; }
.bs-marca-count { font-size: 11px; color: #7a7a8a; }
.bs-marca-card.is-active .bs-marca-count { color: #e8350f; }
.bs-panel-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 24px; gap: 16px; }
.bs-panel-title h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 32px; text-transform: uppercase; color: #f0eff5; line-height: 1; margin-top: 6px; }
.bs-modelos-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.bs-modelo-chip { background: #18181d; border: 1px solid #2a2a33; color: #f0eff5; padding: 10px 20px; font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: all .22s; }
.bs-modelo-chip:hover { background: rgba(232,53,15,.08); border-color: #e8350f; color: #e8350f; }
.bs-modelo-chip.is-active { background: #e8350f; border-color: #e8350f; color: white; }
.bs-categorias-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
.bs-cat-card { background: #18181d; border: 1px solid #2a2a33; border-radius: 4px; padding: 28px 16px 20px; cursor: pointer; text-align: center; transition: all .22s; display: flex; flex-direction: column; align-items: center; gap: 10px; text-decoration: none; color: #f0eff5; }
.bs-cat-card:hover { border-color: #e8350f; transform: translateY(-3px); box-shadow: 0 12px 40px rgba(232,53,15,.15); }
.bs-cat-icon { font-size: 28px; line-height: 1; }
.bs-cat-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: .04em; text-transform: uppercase; line-height: 1.2; }
.bs-cat-card:hover .bs-cat-name { color: #e8350f; }
.bs-btn-outline { background: transparent; color: #7a7a8a; border: 1px solid #2a2a33; padding: 10px 20px; font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 13px; letter-spacing: .06em; text-transform: uppercase; cursor: pointer; border-radius: 4px; transition: all .22s; }
.bs-btn-outline:hover { color: #f0eff5; }
@media (max-width: 1100px) { .bs-marcas-grid { grid-template-columns: repeat(3, 1fr); } .bs-categorias-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 600px) { .bs-marcas-grid { grid-template-columns: repeat(2, 1fr); } .bs-categorias-grid { grid-template-columns: repeat(2, 1fr); } .bs-panel-header { flex-direction: column; align-items: flex-start; } }
</style>

<script>
window.ANSA = window.ANSA || {};
(function(){
  var selectedMarca = null, selectedModelo = null, selectedNombre = null;
  ANSA.selectMarca = function(card) {
    selectedMarca = card.dataset.marca; selectedNombre = card.dataset.nombre; selectedModelo = null;
    document.querySelectorAll('.bs-marca-card').forEach(function(c){ c.classList.toggle('is-active', c === card); });
    var modelos = card.dataset.modelos.split('|');
    var grid = document.getElementById('bs-modelos-grid');
    grid.innerHTML = modelos.map(function(m){ return '<button class="bs-modelo-chip" onclick="ANSA.selectModelo(this)">' + m + '</button>'; }).join('');
    document.getElementById('bs-marca-selected-name').textContent = selectedNombre;
    var panel = document.getElementById('bs-modelos-panel');
    panel.classList.add('is-open');
    document.getElementById('bs-categorias-panel').classList.remove('is-open');
    setTimeout(function(){ panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 60);
  };
  ANSA.selectModelo = function(chip) {
    selectedModelo = chip.textContent.trim();
    document.querySelectorAll('.bs-modelo-chip').forEach(function(c){ c.classList.toggle('is-active', c === chip); });
    document.getElementById('bs-categorias-title').textContent = '03 — Categoria: ' + selectedNombre + ' ' + selectedModelo;
    var catPanel = document.getElementById('bs-categorias-panel');
    catPanel.classList.add('is-open');
    setTimeout(function(){ catPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 60);
  };
  ANSA.goToCollection = function(catHandle) {
    if (!selectedMarca || !selectedModelo) { return false; }
    var slug = selectedModelo.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-');
    window.location.href = '/collections/' + selectedMarca + '--' + slug + '--' + catHandle;
    return false;
  };
  ANSA.closeModelos = function() {
    selectedMarca = null; selectedModelo = null; selectedNombre = null;
    document.querySelectorAll('.bs-marca-card').forEach(function(c){ c.classList.remove('is-active'); });
    document.getElementById('bs-modelos-panel').classList.remove('is-open');
    document.getElementById('bs-categorias-panel').classList.remove('is-open');
    document.getElementById('brand-selector').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };
})();
</script>

{% schema %}
{
  "name": "Selector de Marcas",
  "tag": "div",
  "class": "section-brand-selector",
  "presets": [{ "name": "Selector de Marcas ANSA" }]
}
{% endschema %}